{
  "name": "@kiban/workspace",
  "version": "1.4.0",
  "private": true,
  "description": "kibanCMS - Next-generation headless CMS",
  "author": "Kiban Agency <dev@kiban.pt>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiban-agency/kiban-cms.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "setup": "bash setup.sh",
    "new-client": "bash scripts/new-client.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File setup.ps1",
    "dev": "turbo dev",
    "dev:admin": "cd apps/admin && pnpm dev",
    "dev:api": "cd apps/api && pnpm dev",
    "dev:example": "cd apps/example && pnpm dev",
    "setup:example": "cd apps/example && pnpm run setup",
    "setup:example:windows": "cd apps/example && pnpm run setup:windows",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build --filter=@kiban/* && changeset publish",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0"
}